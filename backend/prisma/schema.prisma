generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Composite (embedded) types ──────────────────────────────────────────────
// Note: Prisma MongoDB connector does not support enum fields.
// Allowed values are enforced at the API boundary via Zod validators.

type ItemBucket {
  plannedDate   DateTime
  currentDate   DateTime
  plannedAmount Float
  currentAmount Float
  currency      String
}

type BudgetItem {
  name          String
  plannedDate   DateTime
  plannedAmount Float
  /// "income" | "expense"
  type          String
  currency      String
  /// "daily" | "weekly" | "monthly" | "quarterly" | "semiannually" | "annually" | "onetime"
  frequency     String
  buckets       ItemBucket[]
}

type BudgetGroup {
  name        String
  /// "incomes" | "expenses"
  type        String
  budgetItems BudgetItem[]
}

type BudgetCategory {
  name         String
  /// "incomes" | "expenses"
  type         String
  budgetGroups BudgetGroup[]
}

// ─── Document models ─────────────────────────────────────────────────────────

model User {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  firstName    String
  lastName     String
  username     String        @unique
  password     String
  budgets      Budget[]
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Budget {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  userId        String           @db.ObjectId
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  beginningDate DateTime
  endingDate    DateTime
  incomes       BudgetCategory[]
  expenses      BudgetCategory[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Transaction {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  txdatetime DateTime
  txcurrency String
  txamount   Float
  /// "income" | "expense"
  txtype     String
  txcategory String
  txgroup    String
  txitem     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
