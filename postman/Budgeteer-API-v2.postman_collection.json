{
  "info": {
    "name": "Budgeteer API v2",
    "description": "Budgeteer REST API. **Variables:** `baseUrl` defaults to `http://localhost:3000/api/v1` — request paths are relative (e.g. `auth/register`). **Flow:** run **Register** or **Login** (saves `authToken` via collection Bearer auth). **Create budget** or **Get my budget** saves `budgetId`. Nested budget bodies use `type` on line items; **Add item** uses `itemType`. **DELETE** category/group/item sends a JSON body. **List transactions (filtered)** is `GET .../transactions/q` (not `:id` = `q`).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "authToken",
      "value": ""
    },
    {
      "key": "budgetId",
      "value": ""
    },
    {
      "key": "transactionId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "description": "",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"username\": \"janedoe\",\n  \"password\": \"secret12345\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const j = pm.response.json();",
                  "  if (j.token) pm.collectionVariables.set('authToken', j.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "description": "",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"janedoe\",\n  \"password\": \"secret12345\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  if (j.token) pm.collectionVariables.set('authToken', j.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/me",
            "description": ""
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/logout",
            "description": ""
          }
        },
        {
          "name": "Unsubscribe (delete account)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/unsubscribe",
            "description": ""
          }
        }
      ]
    },
    {
      "name": "Budget / CRUD",
      "item": [
        {
          "name": "Get my budget",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/budget",
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  if (j.data && j.data.id) pm.collectionVariables.set('budgetId', j.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create budget",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/budget",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"2026 Annual Budget\",\n  \"beginningDate\": \"2026-01-01\",\n  \"endingDate\": \"2026-12-31\",\n  \"incomes\": [],\n  \"expenses\": []\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const j = pm.response.json();",
                  "  if (j.data && j.data.id) pm.collectionVariables.set('budgetId', j.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create budget (with nested tree)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/budget",
            "description": "Nested items use field **type** (`income`/`expense`), not `itemType`.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sample With Tree\",\n  \"beginningDate\": \"2026-01-01\",\n  \"endingDate\": \"2026-12-31\",\n  \"incomes\": [\n    {\n      \"name\": \"Work\",\n      \"type\": \"incomes\",\n      \"budgetGroups\": [\n        {\n          \"name\": \"Salary\",\n          \"type\": \"incomes\",\n          \"budgetItems\": [\n            {\n              \"name\": \"Monthly Pay\",\n              \"plannedDate\": \"2026-01-01\",\n              \"plannedAmount\": 5000,\n              \"type\": \"income\",\n              \"currency\": \"USD\",\n              \"frequency\": \"monthly\"\n            }\n          ]\n        }\n      ]\n    }\n  ],\n  \"expenses\": []\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Get budget by id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/budget/{{budgetId}}",
            "description": ""
          }
        },
        {
          "name": "Get transactions (for budget owner)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/budget/{{budgetId}}/transactions",
            "description": ""
          }
        },
        {
          "name": "Update budget (partial)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/budget/{{budgetId}}",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"2026 Annual Budget Updated\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Delete budget",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/budget/{{budgetId}}",
            "description": ""
          }
        }
      ]
    },
