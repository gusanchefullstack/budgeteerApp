    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/transactions",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"txdatetime\": \"2026-03-15T10:00:00.000Z\",\n  \"txcurrency\": \"USD\",\n  \"txamount\": 125.5,\n  \"txtype\": \"expense\",\n  \"txcategory\": \"Household\",\n  \"txgroup\": \"Bills\",\n  \"txitem\": \"Electric\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const j = pm.response.json();",
                  "  if (j.data && j.data.id) pm.collectionVariables.set('transactionId', j.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List all transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/transactions",
            "description": ""
