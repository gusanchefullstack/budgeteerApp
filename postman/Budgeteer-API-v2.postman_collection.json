        },
        {
          "name": "List transactions (filtered)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/transactions/q?startDate=2026-01-01&endDate=2026-12-31&txtype=expense",
            "description": "Path must be **/transactions/q** (not `:id`). Optional query: startDate, endDate, txtype, txcategory, txgroup, txitem, txcurrency. If both dates set, endDate >= startDate."
          }
        },
